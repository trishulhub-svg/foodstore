# =============================================
# DELIVX / FOODSTORE - Vercel Deployment Env Vars
# =============================================
#
# Step 1: Go to https://vercel.com → Sign up with GitHub
# Step 2: Import repo: trishulhub-svg/foodstore
# Step 3: In Vercel dashboard, click "Storage" tab → "Create Database" → "Postgres" (Free)
#         This auto-creates DATABASE_URL and DIRECT_URL for you!
# Step 4: Add the 2 remaining env vars below manually
#
# =============================================

# DATABASE_URL - AUTO-FILLED when you add Vercel Postgres storage
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/verceldb?sslmode=require"

# DIRECT_URL - AUTO-FILLED when you add Vercel Postgres storage
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/verceldb?sslmode=require"

# NextAuth Secret - Generate a random string (you can use https://generate-secret.vercel.app/)
NEXTAUTH_SECRET="your-random-secret-here-min-32-chars"

# NextAuth URL - Your Vercel deployment URL (add after first deploy)
NEXTAUTH_URL="https://your-project.vercel.app"
