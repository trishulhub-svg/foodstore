# =============================================
# FOODSTORE - Vercel Deployment Env Vars
# =============================================
#
# ONLY 3 env vars needed:
#
# Step 1: Go to https://vercel.com → Sign up with GitHub
# Step 2: Import repo: trishulhub-svg/foodstore
# Step 3: In Vercel dashboard, click "Storage" → "Create Database" → "Postgres" (Free)
#         This auto-fills DATABASE_URL for you!
# Step 4: Add the other 2 env vars manually (see below)
#
# =============================================

# DATABASE_URL - AUTO-FILLED when you add Vercel Postgres storage
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/verceldb?sslmode=require"

# NextAuth Secret - any random 32+ char string
NEXTAUTH_SECRET="delivx-demo-prod-secret-2026-abcxyz"

# NextAuth URL - your Vercel deployment URL (add after first deploy)
NEXTAUTH_URL="https://your-project.vercel.app"
